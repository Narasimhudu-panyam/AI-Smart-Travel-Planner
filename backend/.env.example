# Copy this file to backend/.env and replace values with your own secrets.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/?appName=<app-name>
MONGODB_DATABASE=smart_travel_planner
# Comma-separated explicit browser origins. Replace with your Vercel production URL.
FRONTEND_ORIGIN=https://your-frontend-domain.vercel.app
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_platform_key
